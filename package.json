{
  "name": "@aelita-dev/oxlint-config",
  "type": "module",
  "version": "1.0.0-beta.9",
  "packageManager": "pnpm@11.1.2",
  "description": "Aelita's OXLint config",
  "author": "Aelita <https://github.com/xsjcTony",
  "license": "MIT",
  "homepage": "https://github.com/xsjcTony/oxlint-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xsjcTony/oxlint-config.git"
  },
  "keywords": [
    "oxlint",
    "oxlint-config",
    "aelita",
    "eslint"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "release": "bumpp",
    "prepack": "pnpm run build",
    "prepare": "simple-git-hooks",
    "publish-ci": "tsx scripts/publish.ts"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "pnpm run lint"
  },
  "peerDependencies": {
    "oxlint": "^1.64.0"
  },
  "dependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tanstack/eslint-plugin-query": "^5.100.10",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "eslint-plugin-antfu": "^3.2.3",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-playwright": "^2.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "local-pkg": "^1.1.2",
    "oxlint-plugin-eslint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "bumpp": "^11.1.0",
    "changelogithub": "^14.0.0",
    "lint-staged": "^17.0.4",
    "oxlint": "^1.64.0",
    "publint": "^0.3.21",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "zx": "^8.8.5"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  }
}
